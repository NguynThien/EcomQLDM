@model EcomQLDM.ViewModels.LoginVM
@{
    Layout = "_adminLayout";
    ViewData["Title"] = "DangNhap";
}

<!-- Navbar Start -->
<div class="container-fluid bg-theme-primary mb-30">
    <div class="row px-xl-5">

        <div class="col-lg-12">
            <nav class="navbar navbar-expand-lg bg-theme-primary navbar-dark py-3 py-lg-0 px-0">
                <a href="" class="text-decoration-none d-block d-lg-none">
                    <span class="h1 text-uppercase text-light bg-primary px-2 ml-n1">Caelum</span>
                </a>
                <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
                    <div class="navbar-nav mr-auto py-0">
                        
                    </div>

                </div>
            </nav>
        </div>
    </div>
</div>
<!-- Navbar End -->

<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-lg-8">
            <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Login</span></h5>
            <form asp-action="DangNhap" asp-route-returnurl="@ViewBag.ReturnUrl">
                <div class="text-danger" asp-validation-summary="All"></div>
                <div class="row">
                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.UserName"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.UserName" />
                        <span asp-validation-for="@Model.UserName" class="text-danger"></span>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.Password"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.Password" />
                        <span asp-validation-for="@Model.Password" class="text-danger"></span>
                    </div>

                </div>

                <div class="row">
                    <div class="col-md-8 form-group">
                        <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2">Login</button>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

