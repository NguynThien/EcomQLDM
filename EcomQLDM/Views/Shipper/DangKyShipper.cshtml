@model EcomQLDM.ViewModels.ShipperVM
@{
    ViewData["Title"] = "Shipper";
}

<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-lg-8">
            <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Shipper</span></h5>
            <form asp-action="DangKyShipper" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-8 form-group">
                        <label>Username</label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.MaShipper" />
                    </div>

                    <div class="col-md-8 form-group">
                        <label>Mật Khẩu</label><sup>*</sup>
                        <input type="password" class="form-control" asp-for="@Model.MatKhau"/>
                    </div>

                    <div class="col-md-8 form-group">
                        <label></label>Hộ Tên<sup>*</sup>
                        <input class="form-control" asp-for="@Model.TenShipper"/>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.Email"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.Email" />
                        <span asp-validation-for="@Model.Email" class="text-danger"></span>
                    </div>

                    <div class="col-md-12 form-group">
                        <div class="custom-control custom-checkbox">
                            <input asp-for="@Model.GioiTinhBool" class="custom-control-input">
                            <label class="custom-control-label" for="GioiTinhBool">Nam</label>
                        </div>
                    </div>

                    <div class="col-md-8 form-group">
                        <label>Số Điện Thoại</label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.DienThoai" />
                        <span asp-validation-for="@Model.DienThoai" class="text-danger"></span>
                    </div>

                    <div class="col-md-8 form-group">
                        <label for="Hinh">Image<sup>*</sup></label>
                        <input type="file" name="Hinh" class="form-control"/>
                    </div>

                </div>

                <div class="row">
                    <div class="col-md-8 form-group">
                        <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2">Đăng Ký</button>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

