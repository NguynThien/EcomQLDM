@* @model IEnumerable<EcomQLDM.ViewModels.HoaDonVM> *@
    @model EcomQLDM.ViewModels.LichSuHD
@{
    ViewData["Title"] = "Lịch Sử Mua Hàng";
    Layout = "_Layout";
}

@* @await Html.PartialAsync("ProductItem", Model) *@

<!-- Cart Start -->
<div class="container-fluid">
    <div class="row px-xl-5">
        @foreach (var item in Model.ThongTinKH)
        {
        <div class="col-lg-3">
                <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Thông Tin Cá Nhân</span></h5>
            <form enctype="multipart/form-data">
                <div class="row">

                    <div class="col-md-8 form-group">
                        <img class="img-fluid w-44 h-44" src="~/Hinh/KhachHang/@item.Hinh">
                    </div>

                    <div class="col-md-8 form-group">
                            <label asp-for="@item.MaKh"></label>
                        :
                        <b>@item.MaKh</b>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@item.HoTen"></label>
                        :
                        <b>@item.HoTen</b>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@item.GioiTinh"></label>
                        :
                        <b>@item.GioiTinh</b>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@item.NgaySinh"></label>
                        :
                        <b>@item.NgaySinh</b>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@item.DiaChi"></label>
                        :
                        <b>@item.DiaChi</b>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@item.Email"></label>
                        :
                        <b>@item.Email</b>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@item.DienThoai"></label>
                        :
                        <b>@item.DienThoai</b>
                    </div>


                </div>

            </form>
        </div>
        }
        
        <div class="col-lg-9 table-responsive mb-5">
            <h4>DANH SÁCH ĐƠN HÀNG</h4>
            <table class="table table-light table-borderless table-hover text-center mb-0">
                <thead class="thead-dark">
                    <tr>
                        <th></th>
                        <th>Tên Hàng</th>
                        <th>Mã Đ.Hàng</th>
                        <th>Ngày Đặt Hàng</th>
                        <th style="width: 200px;">Đ.Chỉ Nhận Hàng</th>
                        <th>Trạng Thái</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody class="align-middle">
                    @foreach (var item in Model.DanhSachDH)
                    {
                        <tr>
                            <td class="align-middle">
                                <img src="~/Hinh/HangHoa/@item.Hinh" alt="@item.TenHang" style="width: 50px;">
                            </td>
                            <td class="align-middle">@item.TenHang</td>
                            <td class="align-middle"><a asp-action="Detail" asp-controller="HoaDon" asp-route-id="@item.MaDh">Đơn hàng @item.MaDh</a></td>
                            <td class="align-middle">@item.NgayLapDh.ToString("dd-MM-yyyy")</td>
                            <td class="align-middle"><p>@item.DiaChiGiaoHang</p></td>
                            <td class="align-middle text-trangthai-@item.MaTrangThai"><b>@item.TrangThai</b></td>
                            <td class="align-middle"><a href="#@item.MaDh" class="btn btn-sm btn-danger">Hủy Đơn Hàng</a></td>
                            <!-- Popup start -->
                            <div id="@item.MaDh" class="popup">
                                <div class="popup-content">
                                    <h2>Xác nhận yêu cầu</h2>
                                    <p>Người dùng có muốn hủy đơn hàng</p>
                                    <a href="" style="display: inline-block; margin-top: 10px; padding: 5px 10px;
		                            background-color: #dc3545; color: #fff; text-decoration: none; border-radius: 3px;">
                                        Không
                                    </a>
                                    <a asp-action="HuyDonHang" asp-controller="HoaDon" asp-route-id="@item.MaDh" style="display: inline-block; margin-top: 10px; padding: 5px 10px;
		                            background-color: #28a745; color: #fff; text-decoration: none; border-radius: 3px;">
                                        Xác nhận
                                    </a>
                                </div>
                            </div>
                            <!-- Popup End -->
                        </tr>
                    }
                    @foreach (var item in Model.DanhSachDH2)
                    {
                        <tr>
                            <td class="align-middle">
                                <img src="~/Hinh/HangHoa/@item.Hinh" alt="@item.TenHang" style="width: 50px;">
                            </td>
                            <td class="align-middle">@item.TenHang</td>
                            <td class="align-middle"><a asp-action="Detail" asp-controller="HoaDon" asp-route-id="@item.MaDh">Đơn hàng @item.MaDh</a></td>
                            <td class="align-middle">@item.NgayLapDh.ToString("dd-MM-yyyy")</td>
                            <td class="align-middle"><p>@item.DiaChiGiaoHang</p></td>
                            <td class="align-middle text-trangthai-@item.MaTrangThai"><b>@item.TrangThai</b></td>
                            <td class="align-middle"></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="col-lg-3 table-responsive mb-5">
        </div>
        
    </div>
</div>
<!-- Cart End -->
