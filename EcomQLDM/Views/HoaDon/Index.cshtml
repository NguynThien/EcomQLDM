@model IEnumerable<EcomQLDM.ViewModels.HoaDonVM>
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";
}

@* @await Html.PartialAsync("ProductItem", Model) *@

<!-- Cart Start -->
<div class="container-fluid">
    <div class="row px-xl-5">
        <h2>Quản Lý Hóa Đơn</h2>
        <div class="col-lg-12 table-responsive mb-5">
            <table class="table table-light table-borderless table-hover text-center mb-0">
                <thead class="thead-dark">
                    <tr>
                        <th>Mã HĐ</th>
                        <th>Ngày Đặt</th>
                        <th>N.Giao Dự Kiến</th>
                        <th>Ngày Nhận</th>
                        <th>Dịa Chỉ</th>
                        <th>C.Thanh Toán</th>
                        <th>Hủy Hóa Đơn</th>
                    </tr>
                </thead>
                <tbody class="align-middle">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="align-middle">@item.MaHD</td>
                            <td class="align-middle">@item.NgayDat.ToString("dd-MM-yyyy")</td>
                            <td class="align-middle">@item.NgayCan.ToString("dd-MM-yyyy")</td>
                            <td class="align-middle">@item.NgayGiao.ToString("dd-MM-yyyy")</td>
                            <td class="align-middle"><p>@item.DiaChi</p></td>
                            <td class="align-middle">@item.CachThanhToan</td>
                            <td class="align-middle"><a asp-action="HuyHoaDon" asp-controller="HoaDon" asp-route-id="@item.MaHD" class="btn btn-sm btn-danger"><i class="fa fa-times"></i></a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>
<!-- Cart End -->
