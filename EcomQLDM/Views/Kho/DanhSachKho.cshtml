@{
    Layout = "_adminLayout";
}

@model IEnumerable<EcomQLDM.ViewModels.KhoVM>
@{
    ViewData["Title"] = "Danh Sách Kho";
}

<!-- Navbar Start -->
<div class="container-fluid bg-theme-primary mb-30">
    <div class="row px-xl-5">

        <div class="col-lg-12">
            <nav class="navbar navbar-expand-lg bg-theme-primary navbar-dark py-3 py-lg-0 px-0">
                <a href="" class="text-decoration-none d-block d-lg-none">
                    <span class="h1 text-uppercase text-light bg-primary px-2 ml-n1">Caelum</span>
                </a>
                <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
                    <div class="navbar-nav mr-auto py-0">
                        <a asp-controller="NhanVien" asp-action="PhanQuyen" class="nav-item nav-link">Quản Lý</a>

                    </div>

                </div>
            </nav>
        </div>
    </div>
</div>
<!-- Navbar End -->

<div class="container-fluid">
    <div class="row px-xl-5">
        <h2>Danh Sách Kho Hàng</h2>
        <div class="col-lg-12 table-responsive mb-5">
            <table class="table table-light table-borderless table-hover text-center mb-0">
                <thead class="thead-dark">
                    <tr>
                        <th>Mã Kho</th>
                        <th>Tên Kho</th>
                        <th>Địa Chỉ</th>
                        <th>Quản Đốc</th>
                        <th>Số Điện Thoại</th>
                        <th>Email</th>
                        <th>Chi Tiết Kho</th>
                        <th><a asp-action="ThemKhoHang" asp-controller="Kho" class="btn btn-sm btn-success">Thêm Kho <i class="fa fa-plus"></i></a></th>
                    </tr>
                </thead>
                <tbody class="align-middle">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="align-middle">@item.MaKho</td>
                            <td class="align-middle">@item.TenKho</td>
                            <td class="align-middle">@item.DiaChi</td>
                            <td class="align-middle">@item.HoTenQuanDoc</td>
                            <td class="align-middle">@item.DienThoai</td>
                            <td class="align-middle">@item.Email</td>
                            <td class="align-middle"><a asp-action="DetailPN" asp-controller="Kho" asp-route-id="@item.MaKho" class="btn btn-sm btn-warning"><i class="fa fa-ellipsis-h"></i></a></td>
                            <td class="align-middle"></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
