@using EcomQLDM.ViewModels
@{
    Layout = "_adminLayout";
}

@model EcomQLDM.ViewModels.ChiTietPNVM
@{
    ViewData["Title"] = "Nhập Hàng";

    var hanghoa = ViewData["HangHoa"] as List<HangHoaVM>;
}

<!-- Navbar Start -->
<div class="container-fluid bg-theme-primary mb-30">
    <div class="row px-xl-5">

        <div class="col-lg-12">
            <nav class="navbar navbar-expand-lg bg-theme-primary navbar-dark py-3 py-lg-0 px-0">
                <a href="" class="text-decoration-none d-block d-lg-none">
                    <span class="h1 text-uppercase text-light bg-primary px-2 ml-n1">Caelum</span>
                </a>
                <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
                    <div class="navbar-nav mr-auto py-0">
                        <a asp-controller="NhanVien" asp-action="PhanQuyen" class="nav-item nav-link">Quản Lý</a>

                    </div>

                </div>
            </nav>
        </div>
    </div>
</div>
<!-- Navbar End -->

<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-lg-6">
            <h5 class="position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Thêm Kho Hàng</span></h5>
            <form asp-controller="Kho" asp-action="NhapThemHang" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.MaPN"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.MaPN" value="@ViewBag.MaPN" disabled />
                        <span asp-validation-for="@Model.MaPN" class="text-danger"></span>
                    </div>
                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.MaPN"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.MaPN" value="@ViewBag.MaPN" hidden />
                        <span asp-validation-for="@Model.MaPN" class="text-danger"></span>
                    </div>
                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.TenHH"></label><sup>*</sup>
                        <select asp-for="@Model.TenHH" class="form-control" asp-items="ViewBag.TenHH"></select>
                        <span asp-validation-for="@Model.TenHH" class="text-danger"></span>
                    </div>
                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.SoLuong"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.SoLuong" />
                        <span asp-validation-for="@Model.SoLuong" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-8 form-group">
                        <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2">Nhập Hàng</button>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-8 form-group">
                        <a asp-action="ChiTietPN" asp-controller="Kho" asp-route-id="@ViewBag.MaPN" class="btn btn-block btn-primary font-weight-bold py-2">Xuất Phiếu</a>
                    </div>
                </div>
            </form>
            
        </div>

        <div class="col-lg-6">
            <h5 class="position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Các hàng mới</span></h5>
            <table class="table table-light table-borderless table-hover text-center mb-0">
                <thead class="thead-dark">
                    <tr>
                        <th>Hình</th>
                        <th>Giá</th>
                        <th>Tên hàng</th>
                        <th>Số lượng</th>
                    </tr>
                </thead>
                <tbody class="align-middle">
                    @foreach (var item in hanghoa)
                    {
                        <tr>
                            <td class="align-middle">
                                <img src="~/Hinh/HangHoa/@item.Hinh1" alt="@item.TenHH" style="width: 50px;">
                            </td>
                            <td class="align-middle">@item.DonGia.ToString("#,##0 đ")</td>
                            <td class="align-middle">@item.TenHH</td>
                            <td class="align-middle">@item.SoLuongHH</td>
                        </tr>

                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
