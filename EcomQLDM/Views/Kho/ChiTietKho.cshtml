@{
    Layout = "_adminLayout";
}

@model EcomQLDM.ViewModels.QLKhoVM
@{
    ViewData["Title"] = "Chuc Nang";
}

<!-- Navbar Start -->
<div class="container-fluid bg-theme-primary mb-30">
    <div class="row px-xl-5">

        <div class="col-lg-12">
            <nav class="navbar navbar-expand-lg bg-theme-primary navbar-dark py-3 py-lg-0 px-0">
                <a href="" class="text-decoration-none d-block d-lg-none">
                    <span class="h1 text-uppercase text-light bg-primary px-2 ml-n1">Caelum</span>
                </a>
                <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
                    <div class="navbar-nav mr-auto py-0">
                        <a asp-controller="NhanVien" asp-action="PhanQuyen" class="nav-item nav-link">Quản Lý</a>

                    </div>

                </div>
            </nav>
        </div>
    </div>
</div>
<!-- Navbar End -->

<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-lg-4">
            @foreach (var item in Model.ThongTinKho)
            {
                <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Profile</span></h5>
                <form enctype="multipart/form-data">
                    <div class="row">
                    <div class="col-md-8 form-group">
                        <label asp-for="@item.MaKho"></label>
                        :
                            <b>@item.MaKho</b>
                    </div>
                    <div class="col-md-8 form-group">
                        <label asp-for="@item.TenKho"></label>
                        :
                        <b>@item.TenKho</b>
                    </div>
                    <div class="col-md-8 form-group">
                            <label asp-for="@item.HoTenQuanDoc"></label>
                        :
                            <b>@item.HoTenQuanDoc</b>
                    </div>
                    <div class="col-md-8 form-group">
                            <label asp-for="@item.DiaChi"></label>
                        :
                            <b>@item.DiaChi</b>
                    </div>

                    <div class="col-md-8 form-group">
                            <label asp-for="@item.Email"></label>
                        :
                            <b>@item.Email</b>
                    </div>

                    <div class="col-md-8 form-group">
                            <label asp-for="@item.DienThoai"></label>
                        :
                            <b>@item.DienThoai</b>
                    </div>
                </div>
            </form>
        }
        </div>
        <div class="col-md-8 form-group">
            <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3"></span></h5>

            <table class="table table-light table-borderless table-hover text-center mb-0">
                <thead class="thead-dark">
                    <tr>
                        <th>Hình</th>
                        <th>Mã Hàng Hóa</th>
                        <th>Tên Hàng</th>
                        <th>Đơn</th>
                        <th>Số Lượng</th>
                        <th>Nhập Hàng</th>
                        <th>Xuất Hàng</th>
                    </tr>
                </thead>
                <tbody class="align-middle">
                    @foreach (var item in Model.DanhSachHH)
                    {
                        <tr>
                            <td class="align-middle">
                                <img src="~/Hinh/HangHoa/@item.Hinh1" alt="@item.TenHH" style="width: 50px;">
                            </td>
                            <td class="align-middle">@item.MaHh</td>
                            <td class="align-middle">@item.TenHH</td>
                            <td class="align-middle">@item.DonGia</td>
                            <td class="align-middle">@item.SoLuongHH</td>
                            <td class="align-middle"><a asp-action="ChiTietPN" asp-controller="Kho" asp-route-id="1" class="btn btn-sm btn-info">Nhập Hàng</a></td>
                            <td class="align-middle"><a asp-action="ChiTietPN" asp-controller="Kho" asp-route-id="1" class="btn btn-sm btn-info">Xuất Hàng</a></td>

                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="col-lg-4">
            <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3"></span></h5>
            
        </div>
        
        
    </div>
</div>
