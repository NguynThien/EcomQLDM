@{
    Layout = "_adminLayout";
}

@model EcomQLDM.ViewModels.KhoVM
@{
    ViewData["Title"] = "Danh Sách Kho";
}

<!-- Navbar Start -->
<div class="container-fluid bg-theme-primary mb-30">
    <div class="row px-xl-5">

        <div class="col-lg-12">
            <nav class="navbar navbar-expand-lg bg-theme-primary navbar-dark py-3 py-lg-0 px-0">
                <a href="" class="text-decoration-none d-block d-lg-none">
                    <span class="h1 text-uppercase text-light bg-primary px-2 ml-n1">Caelum</span>
                </a>
                <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
                    <div class="navbar-nav mr-auto py-0">
                        <a asp-controller="NhanVien" asp-action="PhanQuyen" class="nav-item nav-link">Quản Lý</a>

                    </div>

                </div>
            </nav>
        </div>
    </div>
</div>
<!-- Navbar End -->

<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-lg-8">
            <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Thêm Kho Hàng</span></h5>
            <form asp-controller="Kho" asp-action="ThemKhoHang" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.MaKho"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.MaKho" />
                        <span asp-validation-for="@Model.MaKho" class="text-danger"></span>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.TenKho"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.TenKho" />
                        <span asp-validation-for="@Model.TenKho" class="text-danger"></span>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.DiaChi"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.DiaChi" />
                        <span asp-validation-for="@Model.DiaChi" class="text-danger"></span>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.HoTenQuanDoc"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.HoTenQuanDoc" />
                        <span asp-validation-for="@Model.HoTenQuanDoc" class="text-danger"></span>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.DienThoai"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.DienThoai" />
                        <span asp-validation-for="@Model.DienThoai" class="text-danger"></span>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.Email"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.Email" />
                        <span asp-validation-for="@Model.Email" class="text-danger"></span>
                    </div>

                </div>

                <div class="row">
                    <div class="col-md-8 form-group">
                        <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2">Tạo Kho</button>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>
