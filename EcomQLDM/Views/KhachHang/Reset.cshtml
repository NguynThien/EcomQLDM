@model EcomQLDM.ViewModels.ResetPasswordVM

@{
    ViewData["Title"] = "Reset Password";
}

<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-lg-8">
            <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Profile</span></h5>
            <form asp-controller="KhachHang" asp-action="ResetPassword" method="post" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-8 form-group">
                        <input type="hidden" class="form-control" asp-for="@Model.MaKh" placeholder="@Model.MaKh" />
                    </div>
                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.Password"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.Password" placeholder="" />
                        <span asp-validation-for="@Model.Password" class="text-danger"></span>
                    </div>
                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.Password2"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.Password2" placeholder="" />
                        <span asp-validation-for="@Model.Password2" class="text-danger"></span>
                        <p class="text-danger">@ViewBag.Message</p>
                    </div>

                </div>

                <div class="row">
                    <div class="col-md-8 form-group">
                        <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2">Submit</button>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>
