@model EcomQLDM.ViewModels.RegisterVM
@{
    ViewData["Title"] = "Register";
}

<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-lg-8">
            <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Register</span></h5>
            <form asp-action="DangKy" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.MaKh"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.MaKh"/>
                        <span asp-validation-for="@Model.MaKh" class="text-danger"></span>
                    </div>
                    @* <div class="col-md-8 form-group">
                        <label>Email</label><sup>*</sup>
                        <input class="form-control"/>
                    </div> *@
                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.MatKhau"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.MatKhau"/>
                        <span asp-validation-for="@Model.MatKhau" class="text-danger"></span>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.HoTen"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.HoTen"/>
                        <span asp-validation-for="@Model.HoTen" class="text-danger"></span>
                    </div>

                    <div class="col-md-12 form-group">
                        <div class="custom-control custom-checkbox">
                            <input asp-for="@Model.GioiTinh" class="custom-control-input">
                            <label class="custom-control-label" for="GioiTinh">Nam</label>
                        </div>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.NgaySinh"></label>
                        <input class="form-control" asp-for="@Model.NgaySinh" />
                        <span asp-validation-for="@Model.NgaySinh" class="text-danger"></span>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.DiaChi"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.DiaChi" />
                        <span asp-validation-for="@Model.DiaChi" class="text-danger"></span>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.DienThoai"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.DienThoai" />
                        <span asp-validation-for="@Model.DienThoai" class="text-danger"></span>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.Email"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.Email" />
                        <span asp-validation-for="@Model.Email" class="text-danger"></span>
                    </div>

                    <div class="col-md-8 form-group">
                        <label for="Hinh">Image<sup>*</sup></label>
                        <input type="file" name="Hinh" class="form-control"/>
                    </div>

                </div>

                <div class="row">
                    <div class="col-md-8 form-group">
                        <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2">Register</button>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

