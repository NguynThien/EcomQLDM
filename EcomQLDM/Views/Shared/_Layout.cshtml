
<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <meta charset="utf-8">
    <meta content="Free HTML Templates" name="keywords">
    <meta content="Free HTML Templates" name="description">

    <!-- Favicon -->
    <link href="img/favicon.ico" rel="icon">

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">

    <!-- Libraries Stylesheet -->
    <link href="~/lib/animate/animate.min.css" rel="stylesheet">
    <link href="~/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">

    <!-- Customized Bootstrap Stylesheet -->
    <link href="~/css/style.css" rel="stylesheet">
    @RenderSection("Styles", required: false)
</head>
<body>
    <div>
        <!-- Topbar Start -->
        <div class="container-fluid bg-banner">
            <div class="row py-1 px-xl-5">
                
            </div>
            <div class="row align-items-center py-3 px-xl-5 d-none d-lg-flex">
                <div class="col-lg-4">
                    <a href="/" class="text-decoration-none">
                        <span class="h1 text-uppercase text-light bg-primary px-2 ml-n1">Caelum</span>
                    </a>
                </div>
                <div class="col-lg-4 col-6 text-left">
                    
                </div>
                <div class="col-lg-4 col-6 text-right">
                    <form asp-action="Search" asp-controller="HangHoa">
                        <div class="input-group">
                            <input id="searchText" type="search" class="form-control" placeholder="Tìm kiếm" name="query">
                            <div class="input-group-append">
                                <button>
                                    <span id="searchButton" class="input-group-text bg-transparent text-primary">
                                        <i class="fa fa-search"></i>
                                    </span>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <!-- Topbar End -->
        <!-- Navbar Start -->
        <div class="container-fluid bg-theme-primary mb-30">
            <div class="row px-xl-5">
                <div class="col-lg-3 d-none d-lg-block">
                    <a class="btn d-flex align-items-center justify-content-between bg-theme-dark w-100" data-toggle="collapse" href="#navbar-vertical" style="height: 65px; padding: 0 30px;">
                        <h6 class="text-secondary m-0"><i class="fa fa-bars mr-2"></i>DANH MỤC SẢN PHẨM</h6>
                        <i class="fa fa-angle-down text-secondary"></i>
                    </a>
                    <nav class="collapse position-absolute navbar navbar-vertical navbar-light align-items-start p-0 bg-light" id="navbar-vertical" style="width: calc(100% - 30px); z-index: 999;">
                        <div class="navbar-nav w-100">
                            <div class="nav-item dropdown dropright">
                                <a asp-controller="HangHoa" asp-action="Shop" asp-route-loai="3" class="nav-link dropdown-toggle"><img src="~/Hinh/Loai/tv.png" class="icon-custom">TIVI <i class="fa fa-angle-right float-right mt-1"></i></a>
                                <div class="dropdown-menu position-absolute rounded-0 border-0 m-0">
                                    <a class="nav-link dropdown-toggle text-primary" data-toggle="dropdown">Kích thước</a>
                                    <div class="dropdown-menu position-absolute rounded-0 border-0 m-0">
                                        <a class="dropdown-item text-primary">Thương hiệu</a>
                                        <a href="/HangHoa/ThuongHieu?loai=3&thuonghieu=LG" class="dropdown-item">LG</a>
                                        <a href="/HangHoa/ThuongHieu?loai=3&thuonghieu=Samsung" class="dropdown-item">Samsung</a>
                                        <a href="/HangHoa/ThuongHieu?loai=3&thuonghieu=Sony" class="dropdown-item">Sony</a>
                                        <a href="/HangHoa/ThuongHieu?loai=3&thuonghieu=Toshiba" class="dropdown-item">Toshiba</a>
                                    </div>
                                    <a href="/HangHoa/KichThuoc?loai=3&kichthuoc=4" class="dropdown-item">40" - 49"</a>
                                    <a href="/HangHoa/KichThuoc?loai=3&kichthuoc=5" class="dropdown-item">50" - 59"</a>
                                    <a href="/HangHoa/KichThuoc?loai=3&kichthuoc=6" class="dropdown-item">60" - 69"</a>
                                </div>
                            </div>
                            <div class="nav-item dropdown dropright">
                                <a asp-controller="HangHoa" asp-action="Shop" asp-route-loai="5" class="nav-link dropdown-toggle"><img src="~/Hinh/Loai/laundry-service.png" class="icon-custom">Máy Giặt <i class="fa fa-angle-right float-right mt-1"></i></a>
                                <div class="dropdown-menu position-absolute rounded-0 border-0 m-0">
                                    <a class="nav-link dropdown-toggle text-primary" data-toggle="dropdown">Kích thước</a>
                                    <div class="dropdown-menu position-absolute rounded-0 border-0 m-0">
                                        <a class="dropdown-item text-primary">Thương hiệu</a>
                                        <a href="/HangHoa/ThuongHieu?loai=5&thuonghieu=Electrolux" class="dropdown-item">Electrolux</a>
                                        <a href="/HangHoa/ThuongHieu?loai=5&thuonghieu=Samsung" class="dropdown-item">Samsung</a>
                                        <a href="/HangHoa/ThuongHieu?loai=5&thuonghieu=LG" class="dropdown-item">LG</a>
                                        <a href="/HangHoa/ThuongHieu?loai=5&thuonghieu=Toshiba" class="dropdown-item">Toshiba</a>
                                    </div>
                                    <a href="/HangHoa/KichThuoc?loai=5&kichthuoc=5" class="dropdown-item">5kg - 10kg</a>
                                    <a href="/HangHoa/KichThuoc?loai=5&kichthuoc=10" class="dropdown-item">10kg - 15kg</a>
                                    <a href="/HangHoa/KichThuoc?loai=5&kichthuoc=15" class="dropdown-item">15kg - 25kg</a>
                                </div>
                            </div>
                            <div class="nav-item dropdown dropright">
                                <a asp-controller="HangHoa" asp-action="Shop" asp-route-loai="1" class="nav-link dropdown-toggle"><img src="~/Hinh/Loai/air-conditioner.png" class="icon-custom">Máy Lạnh <i class="fa fa-angle-right float-right mt-1"></i></a>
                                <div class="dropdown-menu position-absolute rounded-0 border-0 m-0">
                                    <a class="nav-link dropdown-toggle text-primary" data-toggle="dropdown">Kích thước</a>
                                    <div class="dropdown-menu position-absolute rounded-0 border-0 m-0">
                                        <a class="dropdown-item text-primary">Thương hiệu</a>
                                        <a href="/HangHoa/ThuongHieu?loai=1&thuonghieu=Panasonic" class="dropdown-item">Panasonic</a>
                                        <a href="/HangHoa/ThuongHieu?loai=1&thuonghieu=Daikin" class="dropdown-item">Daikin</a>
                                        <a href="/HangHoa/ThuongHieu?loai=1&thuonghieu=LG" class="dropdown-item">LG</a>
                                        <a href="/HangHoa/ThuongHieu?loai=1&thuonghieu=Casper" class="dropdown-item">Casper</a>
                                        <a href="/HangHoa/ThuongHieu?loai=1&thuonghieu=Aqua" class="dropdown-item">Aqua</a>
                                    </div>
                                    <a href="/HangHoa/KichThuoc?loai=1&kichthuoc=1" class="dropdown-item">1 HP</a>
                                    <a href="/HangHoa/KichThuoc?loai=1&kichthuoc=2" class="dropdown-item">2 HP</a>
                                </div>
                            </div>
                            <div class="nav-item dropdown dropright">
                                <a asp-controller="HangHoa" asp-action="Shop" asp-route-loai="2" class="nav-link dropdown-toggle"><img src="~/Hinh/Loai/fridge.png" class="icon-custom">Tủ Lạnh <i class="fa fa-angle-right float-right mt-1"></i></a>
                                <div class="dropdown-menu position-absolute rounded-0 border-0 m-0">
                                    <a class="nav-link dropdown-toggle text-primary" data-toggle="dropdown">Kích thước</a>
                                    <div class="dropdown-menu position-absolute rounded-0 border-0 m-0">
                                        <a class="dropdown-item text-primary">Thương hiệu</a>
                                        <a href="/HangHoa/ThuongHieu?loai=2&thuonghieu=Electrolux" class="dropdown-item">Electrolux</a>
                                        <a href="/HangHoa/ThuongHieu?loai=2&thuonghieu=Samsung" class="dropdown-item">Samsung</a>
                                        <a href="/HangHoa/ThuongHieu?loai=2&thuonghieu=LG" class="dropdown-item">LG</a>
                                        <a href="/HangHoa/ThuongHieu?loai=2&thuonghieu=Toshiba" class="dropdown-item">Toshiba</a>
                                    </div>
                                    <a href="/HangHoa/KichThuoc?loai=2&kichthuoc=2" class="dropdown-item">200 lít - 400 lít</a>
                                    <a href="/HangHoa/KichThuoc?loai=2&kichthuoc=4" class="dropdown-item">400 lít - 600 lít</a>
                                    <a href="/HangHoa/KichThuoc?loai=2&kichthuoc=6" class="dropdown-item">Trên 600 lít</a>
                                </div>
                            </div>
                            <div class="nav-item dropdown dropright">
                                <a asp-controller="HangHoa" asp-action="Shop" asp-route-loai="6" class="nav-link dropdown-toggle"><img src="~/Hinh/Loai/filtration.png" class="icon-custom">Lọc Nước <i class="fa fa-angle-right float-right mt-1"></i></a>
                                <div class="dropdown-menu position-absolute rounded-0 border-0 m-0">
                                    <a class="nav-link dropdown-toggle text-primary" data-toggle="dropdown">Kích thước</a>
                                    <div class="dropdown-menu position-absolute rounded-0 border-0 m-0">
                                        <a class="dropdown-item text-primary">Thương hiệu</a>
                                        <a href="/HangHoa/ThuongHieu?loai=6&thuonghieu=Sunhouse" class="dropdown-item">Sunhouse</a>
                                        <a href="/HangHoa/ThuongHieu?loai=6&thuonghieu=Kangaroo" class="dropdown-item">Kangaroo</a>
                                        <a href="/HangHoa/ThuongHieu?loai=6&thuonghieu=Karofi" class="dropdown-item">Karofi</a>
                                    </div>
                                    <a href="/HangHoa/KichThuoc?loai=6&kichthuoc=5" class="dropdown-item">5 lõi</a>
                                    <a href="/HangHoa/KichThuoc?loai=6&kichthuoc=10" class="dropdown-item">10 lõi</a>
                                </div>
                            </div>
                            <div class="nav-item dropdown dropright">
                                <a asp-controller="HangHoa" asp-action="Shop" asp-route-loai="4" class="nav-link dropdown-toggle"><img src="~/Hinh/Loai/cooking.png" class="icon-custom">Đồ Dùng Bếp <i class="fa fa-angle-right float-right mt-1"></i></a>
                                <div class="dropdown-menu position-absolute rounded-0 border-0 m-0">
                                    <a class="nav-link dropdown-toggle text-primary" data-toggle="dropdown">Loại</a>
                                    <div class="dropdown-menu position-absolute rounded-0 border-0 m-0">
                                        <a class="dropdown-item text-primary">Thương hiệu</a>
                                        <a href="/HangHoa/ThuongHieu?loai=4&thuonghieu=Philips" class="dropdown-item">Philips</a>
                                        <a href="/HangHoa/ThuongHieu?loai=4&thuonghieu=Sharp" class="dropdown-item">Sharp</a>
                                        <a href="/HangHoa/ThuongHieu?loai=4&thuonghieu=Sunhouse" class="dropdown-item">Sunhouse</a>
                                    </div>
                                    <a href="/HangHoa/KichThuoc?loai=4&kichthuoc=1" class="dropdown-item">Lò vi sóng</a>
                                    <a href="/HangHoa/KichThuoc?loai=4&kichthuoc=2" class="dropdown-item">Nồi cơm điện</a>
                                    <a href="/HangHoa/KichThuoc?loai=4&kichthuoc=3" class="dropdown-item">Chiên không dầu</a>
                                </div>
                            </div>
                            
                        </div>
                    </nav>
                </div>
                <div class="col-lg-9">
                    <nav class="navbar navbar-expand-lg bg-theme-primary navbar-dark py-3 py-lg-0 px-0">
                        <a href="" class="text-decoration-none d-block d-lg-none">
                            <span class="h1 text-uppercase text-light bg-primary px-2 ml-n1">Caelum</span>
                        </a>
                        <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
                            <div class="navbar-nav mr-auto py-0">
                                <a href="/" class="nav-item nav-link">Trang Chủ</a>
                                <a href="/HangHoa/Shop?page=1" class="nav-item nav-link">Mua Hàng</a>
                                <a asp-controller="KhachHang" asp-action="DangKy" class="nav-item nav-link">Đăng Ký</a>
                                
                            </div>
                            
                            <div class="nav navbar-nav navbar-right">
                                @await Component.InvokeAsync("Cart")
                            </div>

                            <div class="nav navbar-nav navbar-right">
                                <a asp-controller="KhachHang" asp-action="Profile" class="btn px-0 ml-3">
                                    <i class="fa fa-user-circle text-primary"></i>
                                </a>

                            </div>

                        </div>
                    </nav>
                </div>
            </div>
        </div>
        <!-- Navbar End -->

        <div>
            @RenderBody()
        </div>


        @await Html.PartialAsync("_Footer")
    </div>



    <!-- Back to Top -->
    <a href="#" class="btn btn-primary back-to-top"><i class="fa fa-angle-double-up"></i></a>


    <!-- JavaScript Libraries -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/easing/easing.min.js"></script>
    <script src="~/lib/owlcarousel/owl.carousel.min.js"></script>

    <!-- Contact Javascript File -->
    <script src="~/mail/jqBootstrapValidation.min.js"></script>
    <script src="~/mail/contact.js"></script>

    <!-- Template Javascript -->
    <script src="~/js/main.js"></script>
    @RenderSection("Scripts", required: false)
    <script>
        $(documnet).ready(function () {
            $("#searchButton").click(function () {
                let url = '/HangHoa/Search?query=' + $(#searchText).val();
                window.location.href = url;
            });
        });
    </script>
</body>
</html>
