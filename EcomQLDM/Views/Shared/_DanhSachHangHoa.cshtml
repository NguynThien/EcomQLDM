@{
    Layout = "_Layout";
}

<!-- Breadcrumb Start -->
@RenderSection("BreadCum", required: false)
<!-- Breadcrumb End -->
<!-- Shop Start -->
<div class="container-fluid">
    <div class="row px-xl-5">
        <!-- Shop Sidebar Start -->
        <div class="col-lg-3 col-md-4">
            @* @await Component.InvokeAsync("MenuCategory") *@

            <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">MENU</span></h5>
            <div class="bg-light p-4 mb-30">
                <ul class="list-unstyled brand_categorie">
                    <li>
                        <div class="d-flex justify-content-between brand-name text-secondary">
                            <a asp-controller="HangHoa" asp-action="Shop" asp-route-loai="1">
                                <img src="~/Hinh/Loai/air-conditioner.png" class="icon-custom"></img>Điều Hòa
                            </a>
                        </div>
                    </li>
                    <li>
                        <div class="d-flex justify-content-between brand-name text-secondary">
                            <a asp-controller="HangHoa" asp-action="Shop" asp-route-loai="2">
                                <img src="~/Hinh/Loai/fridge.png" class="icon-custom"></img>Tủ Lạnh
                            </a>
                        </div>
                    </li>
                    <li>
                        <div class="d-flex justify-content-between brand-name text-secondary">
                            <a asp-controller="HangHoa" asp-action="Shop" asp-route-loai="3">
                                <img src="~/Hinh/Loai/tv.png" class="icon-custom"></img>Tivi
                            </a>
                        </div>
                    </li>
                    <li>
                        <div class="d-flex justify-content-between brand-name text-secondary">
                            <a asp-controller="HangHoa" asp-action="Shop" asp-route-loai="4">
                                <img src="~/Hinh/Loai/cooking.png" class="icon-custom"></img>Đồ dùng bếp
                            </a>
                        </div>
                    </li>
                    <li>
                        <div class="d-flex justify-content-between brand-name text-secondary">
                            <a asp-controller="HangHoa" asp-action="Shop" asp-route-loai="5">
                                <img src="~/Hinh/Loai/laundry-service.png" class="icon-custom"></img>Máy giặc
                            </a>
                        </div>
                    </li>
                    <li>
                        <div class="d-flex justify-content-between brand-name text-secondary">
                            <a asp-controller="HangHoa" asp-action="Shop" asp-route-loai="6">
                                <img src="~/Hinh/Loai/filtration.png" class="icon-custom"></img>Lọc nước
                            </a>
                        </div>
                    </li>
                    <li>
                        <div class="d-flex justify-content-between brand-name text-secondary">
                            <a asp-controller="HangHoa" asp-action="Shop" asp-route-loai="7">
                                <img src="~/Hinh/Loai/laptop.png" class="icon-custom"></img>Laptop, PC
                            </a>
                        </div>
                    </li>
                    <li>
                        <div class="d-flex justify-content-between brand-name text-secondary">
                            <a asp-controller="HangHoa" asp-action="Shop" asp-route-loai="8">
                                <img src="~/Hinh/Loai/smartphone.png" class="icon-custom"></img>Điện Thoại
                            </a>
                        </div>
                    </li>
                    <li>
                        <div class="d-flex justify-content-between brand-name text-secondary">
                            <a asp-controller="HangHoa" asp-action="Shop" asp-route-loai="9">
                                <img src="~/Hinh/Loai/services.png" class="icon-custom"></img>Dịch vụ
                            </a>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
        <!-- Shop Sidebar End -->
        <!-- Shop Product Start -->
        <div class="col-lg-9 col-md-8">
            <div class="row pb-3">

                @RenderBody()

            </div>
        </div>
        <!-- Shop Product End -->
    </div>
</div>
<!-- Shop End -->
