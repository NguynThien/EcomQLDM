@model IEnumerable<EcomQLDM.ViewModels.MenuCategoryVM>

<!-- Color Start -->
<h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">MAKE</span></h5>

<div class="bg-light p-4 mb-30">
    <ul class="list-unstyled brand_categorie">
        @foreach (var item in Model)
        {
            <li>
                <div class="d-flex justify-content-between brand-name">
                    <a asp-controller="HangHoa" asp-action="Index" asp-route-loai="@item.MaLoai">
                        <i class="fas fa-ford-alt me-2"></i>@item.TenLoai
                    </a>
                    <span>[@item.SoLuong]</span>
                </div>
            </li>
        }
    </ul>
</div>
<!-- Color End -->