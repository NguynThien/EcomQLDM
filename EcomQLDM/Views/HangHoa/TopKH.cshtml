@* @model IEnumerable<EcomQLDM.ViewModels.HangHoaVM> *@
@model EcomQLDM.ViewModels.PhanQuyenVM
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_adminLayout";
}

@* @await Html.PartialAsync("ProductItem", Model) *@
<!-- Navbar Start -->
<div class="container-fluid bg-theme-primary mb-30">
    <div class="row px-xl-5">

        <div class="col-lg-12">
            <nav class="navbar navbar-expand-lg bg-theme-primary navbar-dark py-3 py-lg-0 px-0">
                <a href="" class="text-decoration-none d-block d-lg-none">
                    <span class="h1 text-uppercase text-light bg-primary px-2 ml-n1">Caelum</span>
                </a>
                <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
                    <div class="navbar-nav mr-auto py-0">
                        <a asp-controller="NhanVien" asp-action="PhanQuyen" class="nav-item nav-link">Quản lý</a>

                    </div>

                </div>
            </nav>
        </div>
    </div>
</div>
<!-- Navbar End -->
<!-- Cart Start -->
<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-lg-3 col-md-4">
            
            <div class="bg-light p-4 mb-30">
                <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">QUẢN LÝ</span></h5>
                <form asp-controller="HangHoa" asp-action="ThongKe" enctype="multipart/form-data">
                    <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2" @Model.QlHangHoa>Hàng Bán Chạy</button>
                </form>
                <div class="p-2"></div>
                <form asp-controller="HangHoa" asp-action="DoanhThu" enctype="multipart/form-data">
                    <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2" @Model.QlDoanhThu>Doanh Thu</button>
                </form>
                <div class="p-2"></div>
                <form asp-controller="Kho" asp-action="DanhSachKho" enctype="multipart/form-data">
                    <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2" @Model.QlKho>QL Kho</button>
                </form>
            </div>
        </div>
        <div class="col-lg-9 table-responsive mb-5">
            <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Top Khách Hàng</span></h5>
            <table class="table table-light table-borderless table-hover text-center mb-0">
                <thead class="thead-dark">
                    <tr>
                        <th>Số lượng đặt hàng</th>
                        <th>Hình</th>
                        <th>Tên khách hàng</th>
                        <th>Email</th>
                        <th>Số điện thoại</th>
                    </tr>
                </thead>
                <tbody class="align-middle">
                    @foreach (var item in Model.xepHangKHs)
                    {
                        <tr>
                            <td class="align-middle">@item.SoLuongMuaHang</td>
                            <td class="align-middle">
                                <img src="~/Hinh/KhachHang/@item.Hinh" alt="@item.HoTen" style="width: 50px;">
                            </td>
                            <td class="align-middle">@item.HoTen</td>
                            <td class="align-middle">@item.Email</td>
                            <td class="align-middle">@item.DienThoai</td>
                        </tr>
                    
                    }
                </tbody>
            </table>
        </div>
        
    </div>
</div>
<!-- Cart End -->
