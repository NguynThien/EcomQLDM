@* @model IEnumerable<EcomQLDM.ViewModels.HangHoaVM> *@
@model EcomQLDM.ViewModels.PhanQuyenVM
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_adminLayout";
}

@* @await Html.PartialAsync("ProductItem", Model) *@
<!-- Navbar Start -->
<div class="container-fluid bg-theme-primary mb-30">
    <div class="row px-xl-5">

        <div class="col-lg-12">
            <nav class="navbar navbar-expand-lg bg-theme-primary navbar-dark py-3 py-lg-0 px-0">
                <a href="" class="text-decoration-none d-block d-lg-none">
                    <span class="h1 text-uppercase text-light bg-primary px-2 ml-n1">Caelum</span>
                </a>
                <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
                    <div class="navbar-nav mr-auto py-0">
                        <a asp-controller="NhanVien" asp-action="PhanQuyen" class="nav-item nav-link">Quản lý</a>

                    </div>

                </div>
            </nav>
        </div>
    </div>
</div>
<!-- Cart Start -->
<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-lg-3 col-md-4">
            
            <div class="bg-light p-4 mb-30">
                <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">QUẢN LÝ</span></h5>
                <form asp-controller="HangHoa" asp-action="ThongKe" enctype="multipart/form-data">
                    <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2" @Model.QlHangHoa>Hàng Bán Chạy</button>
                </form>
                <div class="p-2"></div>
                <form asp-controller="HangHoa" asp-action="DoanhThu" enctype="multipart/form-data">
                    <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2" @Model.QlDoanhThu>Doanh Thu</button>
                </form>
                <div class="p-2"></div>
                <form asp-controller="Kho" asp-action="DanhSachKho" enctype="multipart/form-data">
                    <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2" @Model.QlKho>QL Kho</button>
                </form>
                
            </div>
        </div>
        <div class="col-lg-9 table-responsive mb-5">
            <br />
            <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">DANH SÁCH HÀNG HÓA</span></h5>
            <br />
            <form asp-action="Dashboard" asp-controller="HangHoa">
                <div class="input-group">
                    <input id="searchText" type="search" class="form-control" placeholder="Tìm kiếm hàng" name="query">
                    <div class="input-group-append">
                        <button>
                            <span id="searchButton" class="input-group-text bg-transparent text-primary">
                                <i class="fa fa-search"></i>
                            </span>
                        </button>
                    </div>
                </div>
            </form>
            <table class="table table-light table-borderless table-hover text-center mb-0">
                <thead class="thead-dark">
                    <tr>
                        <th>Hình</th>
                        <th>Mã HH</th>
                        <th>Giá</th>
                        <th>Tên hàng</th>
                        <th>Sửa</th>
                        <th>Gở Bỏ</th>
                        <th class="align-middle"><a asp-action="AddHH" asp-controller="HangHoa" class="btn btn-sm btn-success">Thêm Hàng <i class="fa fa-plus"></i></a></th>
                    </tr>
                </thead>
                <tbody class="align-middle">
                    @foreach (var item in Model.hangHoas)
                    {
                        <tr>
                            <td class="align-middle">
                                <img src="~/Hinh/HangHoa/@item.Hinh1" alt="@item.TenHH" style="width: 50px;">
                            </td>
                            <td class="align-middle">@item.MaHh</td>
                            <td class="align-middle">@item.DonGia.ToString("#,##0 đ")</td>
                            <td class="align-middle"><a asp-action="Detail" asp-controller="HangHoa" asp-route-id="@item.MaHh">@item.TenHH</a></td>
                            <td class="align-middle"><a asp-action="UpdateHH" asp-controller="HangHoa" asp-route-id="@item.MaHh" class="btn btn-sm btn-warning"><i class="fa fa-wrench"></i></a></td>
                            <td class="align-middle"><a href="#@item.MaHh" class="btn btn-sm btn-danger"><i class="fa fa-times"></i></a></td>
                            <td></td>
                            <!-- Popup start -->
                            <div id="@item.MaHh" class="popup">
                                <div class="popup-content">
                                    <h2>Xác nhận yêu cầu</h2>
                                    <p>Người dùng có muốn gỡ hàng hóa</p>
                                    <a href="" style="display: inline-block; margin-top: 10px; padding: 5px 10px;
		                            background-color: #dc3545; color: #fff; text-decoration: none; border-radius: 3px;">
                                        Không
                                    </a>
                                    <a asp-action="DisableHangHoa" asp-controller="HangHoa" asp-route-id="@item.MaHh" style="display: inline-block; margin-top: 10px; padding: 5px 10px;
		                            background-color: #28a745; color: #fff; text-decoration: none; border-radius: 3px;">
                                        Xác nhận
                                    </a>
                                </div>
                            </div>
                            <!-- Popup End -->
                        </tr>
                    
                        
                    
                    }
                </tbody>
            </table>
        </div>
        
    </div>
</div>
<!-- Cart End -->
