@model EcomQLDM.ViewModels.KhachHangVM

@{
    ViewData["Title"] = "EditNV";
}

<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-lg-8">
            <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Profile</span></h5>
            <form asp-controller="KhachHang" asp-action="Edit" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-8 form-group">
                        <input type="hidden" class="form-control" asp-for="@Model.MaKh" placeholder="@Model.MaKh" />
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.HoTen"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.HoTen" placeholder="@Model.HoTen" />
                        <span asp-validation-for="@Model.HoTen" class="text-danger"></span>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.GioiTinh"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.GioiTinh" placeholder="@Model.GioiTinh" />
                        <span asp-validation-for="@Model.HoTen" class="text-danger"></span>
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.NgaySinh"></label>
                        <input class="form-control" asp-for="@Model.NgaySinh" />
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.DiaChi"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.DiaChi" placeholder="@Model.DiaChi" />
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.Email"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.Email" placeholder="@Model.Email" />
                    </div>

                    <div class="col-md-8 form-group">
                        <label asp-for="@Model.DienThoai"></label><sup>*</sup>
                        <input class="form-control" asp-for="@Model.DienThoai" placeholder="@Model.DienThoai" />
                    </div>

                </div>

                <div class="row">
                    <div class="col-md-8 form-group">
                        <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2">Submit</button>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>
