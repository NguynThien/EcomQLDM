@{
    Layout = "_adminLayout";
}

@model EcomQLDM.ViewModels.PhanQuyenVM
@{
    ViewData["Title"] = "Chuc Nang";
}

<!-- Navbar Start -->
<div class="container-fluid bg-theme-primary mb-30">
    <div class="row px-xl-5">

        <div class="col-lg-12">
            <nav class="navbar navbar-expand-lg bg-theme-primary navbar-dark py-3 py-lg-0 px-0">
                <a href="" class="text-decoration-none d-block d-lg-none">
                    <span class="h1 text-uppercase text-light bg-primary px-2 ml-n1">Caelum</span>
                </a>
                <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
                    <div class="navbar-nav mr-auto py-0">
                        <a asp-controller="NhanVien" asp-action="PhanQuyen" class="nav-item nav-link active">Quản Lý</a>
                        
                    </div>
                    
                    <div class="nav navbar-nav navbar-right">
                        <a asp-controller="NhanVien" asp-action="Profile" class="btn px-0 ml-3">
                            <img class="img-fluid" style="max-width: 20%;" src="~/Hinh/NhanVien/@Model.Hinh">
                        </a>
                            <a asp-controller="NhanVien" asp-action="DangXuat" class="nav-item nav-link">Đăng Xuất</a>

                    </div>

                </div>
            </nav>
        </div>
    </div>
</div>
<!-- Navbar End -->

<div class="container-fluid">
    <div class="row px-xl-5">
    @foreach (var item in Model.phanQuyens)
    {
        <div class="col-lg-4">
            <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Profile</span></h5>
            <form enctype="multipart/form-data">
                <div class="row">

                    <div class="col-md-8 form-group">
                            <img class="img-fluid w-44 h-44" src="~/Hinh/NhanVien/@item.Hinh">
                    </div>

                    <div class="col-md-8 form-group">
                            <label asp-for="@item.MaNV"></label>
                        : 
                            <b>@item.MaNV</b>
                    </div>
                    <div class="col-md-8 form-group">
                            <label asp-for="@item.TenQH"></label>
                        :
                            <b>@item.TenQH</b>
                    </div>
                    <div class="col-md-8 form-group">
                            <label asp-for="@item.HoTen"></label>
                        :
                            <b>@item.HoTen</b>
                    </div>

                    <div class="col-md-8 form-group">
                            <label asp-for="@item.GioiTinh"></label>
                        :
                            <b>@item.GioiTinh</b>
                    </div>

                    <div class="col-md-8 form-group">
                            <label asp-for="@item.DiaChi"></label>
                        :
                            <b>@item.DiaChi</b>
                    </div>

                    <div class="col-md-8 form-group">
                            <label asp-for="@item.Email"></label>
                        :
                            <b>@item.Email</b>
                    </div>

                    <div class="col-md-8 form-group">
                            <label asp-for="@item.DienThoai"></label>
                        :
                            <b>@item.DienThoai</b>
                    </div>

                    
                </div>

            </form>
        </div>
}
        <div class="col-md-3 form-group">
            <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">QUẢN LÝ</span></h5>
            <form asp-controller="HangHoa" asp-action="Dashboard" enctype="multipart/form-data">
                <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2" @Model.QlHangHoa>QL Hàng Hóa</button>
            </form>
            <div class="p-2"></div>
            @* <form asp-controller="HangHoa" asp-action="Dashboard" enctype="multipart/form-data">
                <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2" @Model.QlHoaDon>QL Hóa Đơn</button>
            </form>
            <div class="p-2"></div> *@
            <form asp-controller="Kho" asp-action="DanhSachKho" enctype="multipart/form-data">
                <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2" @Model.QlKho>QL Kho</button>
            </form>
            <div class="p-2"></div>
            <form asp-controller="HangHoa" asp-action="ThongKe" enctype="multipart/form-data">
                <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2" @Model.QlDoanhThu>Thống Kê</button>
            </form>
            <div class="p-2"></div>
            <form asp-controller="HangHoa" asp-action="DoanhThu" enctype="multipart/form-data">
                <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2" @Model.QlDoanhThu>DoanhThu</button>
            </form>
        </div>
        <div class="col-md-3 form-group">
            <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3"></span></h5>
            <form asp-controller="NhanVien" asp-action="DanhSachNhanVien" enctype="multipart/form-data">
                <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2" @Model.QlNhanVien>QL Nhân Viên</button>
            </form>
            <div class="p-2"></div>
            <form asp-controller="Shipper" asp-action="DanhSachShipper" enctype="multipart/form-data">
                <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2" @Model.QlShipper>QL Shipper</button>
            </form>
            <div class="p-2"></div>
            <form asp-controller="HangHoa" asp-action="TopKH" enctype="multipart/form-data">
                <button type="submit" class="btn btn-block btn-primary font-weight-bold py-2" @Model.QlKhachHang>QL Khách Hàng</button>
            </form>
        </div>
    </div>
</div>
