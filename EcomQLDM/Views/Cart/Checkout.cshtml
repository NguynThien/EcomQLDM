@model IEnumerable<EcomQLDM.ViewModels.CartItem>
@{
    ViewData["Title"] = "Checkout";
}

<!-- Checkout Start -->
<div class="container-fluid">
    <form asp-action="Checkout" asp-controller="Cart">
        <div class="row px-xl-5">
            <div class="col-lg-8">
                <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Thông Tin Nhận Hàng</span></h5>
                <div class="bg-light p-30 mb-5">
                    <div class="row">

                        @* <div class="col-md-12 form-group">
                        <div class="custom-control custom-checkbox">
                        <input type="checkbox" class="custom-control-input" name="GiongKhachHang" id="GiongKhachHang" value="false">
                        <label class="custom-control-label" for="GiongKhachHang">Create an account</label>
                        </div>
                        </div> *@

                        <div class="col-md-6 form-group delivery-info">
                            <label>Họ Tên Người Mua</label>
                            <input class="form-control" type="text" name="HoTen" value="@ViewBag.HoTen">
                        </div>
                        <div class="col-md-6 form-group delivery-info">
                            <label>Địa Chỉ</label>
                            <input class="form-control" type="text" name="DiaChi" value="@ViewBag.DiaChi">
                        </div>
                        <div class="col-md-6 form-group delivery-info">
                            <label>Số Điện Thoại</label>
                            <input class="form-control" type="text" name="DienThoai" value="@ViewBag.DienThoai">
                        </div>
                        <div class="col-md-6 form-group">
                            <label>Ghi Chú</label>
                            <input class="form-control" type="textarea" name="GhiChu">
                        </div>

                    </div>
                </div>
                @* <div class="collapse mb-5" id="shipping-address">
                <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Shipping Address</span></h5>
                <div class="bg-light p-30">
                <div class="row">
                <div class="col-md-6 form-group">
                <label>First Name</label>
                <input class="form-control" type="text" placeholder="John">
                </div>
                <div class="col-md-6 form-group">
                <label>Last Name</label>
                <input class="form-control" type="text" placeholder="Doe">
                </div>
                <div class="col-md-6 form-group">
                <label>E-mail</label>
                <input class="form-control" type="text" placeholder="example@email.com">
                </div>
                <div class="col-md-6 form-group">
                <label>Mobile No</label>
                <input class="form-control" type="text" placeholder="+123 456 789">
                </div>
                <div class="col-md-6 form-group">
                <label>Address Line 1</label>
                <input class="form-control" type="text" placeholder="123 Street">
                </div>
                <div class="col-md-6 form-group">
                <label>Address Line 2</label>
                <input class="form-control" type="text" placeholder="123 Street">
                </div>

                <div class="col-md-6 form-group">
                <label>City</label>
                <input class="form-control" type="text" placeholder="New York">
                </div>
                <div class="col-md-6 form-group">
                <label>State</label>
                <input class="form-control" type="text" placeholder="New York">
                </div>
                <div class="col-md-6 form-group">
                <label>ZIP Code</label>
                <input class="form-control" type="text" placeholder="123">
                </div>
                </div>
                </div>
                </div> *@
            </div>
            <div class="col-lg-4">
                <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Thông Tin Mặt Hàng</span></h5>
                <div class="bg-light p-30 mb-5">
                    <div class="border-bottom">
                        <h6 class="mb-3">Hàng</h6>
                        @foreach (var item in Model)
                        {
                            <div class="d-flex justify-content-between">
                                <p>@item.TenHH</p>
                                <p>@item.DonGia.ToString("#,##0 đ")</p>
                            </div>

                        }

                    </div>
                    <div class="border-bottom pt-3 pb-2">
                        <div class="d-flex justify-content-between mb-3">
                            <h6>Total</h6>
                            <h6>@Model.Sum(p => p.ThanhTien).ToString("#,##0 đ")</h6>
                        </div>
                        @* <div class="d-flex justify-content-between">
                        <h6 class="font-weight-medium">Shipping</h6>
                        <h6 class="font-weight-medium">$10</h6>
                        </div> *@
                    </div>
                    @* <div class="pt-2">
                    <div class="d-flex justify-content-between mt-2">
                    <h5>Total</h5>
                    <h5>$160</h5>
                    </div>
                    </div> *@
                </div>
                <div class="mb-5">
                    <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Payment</span></h5>
                    <div class="bg-light p-30">
                        <div class="form-group">
                            <div class="custom-control custom-radio">
                                <input type="radio" class="custom-control-input" name="COD" id="cod" checked>
                                <label class="custom-control-label" for="cod">Thanh Toán Khi Nhận Hàng</label>
                            </div>
                        </div>
                        <div class="form-group">
                            <div class="custom-control custom-radio">
                                <input type="radio" class="custom-control-input" name="payment" id="banktransfer" disabled>
                                <label class="custom-control-label" for="banktransfer">Thẻ Tín Dụng/Ghi Nợ</label>
                            </div>
                        </div>
                        <button class="btn btn-block btn-primary font-weight-bold py-3">Đặt Hàng</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
<!-- Checkout End -->
@section Scripts {
    <script>
        $(document).ready(function () {
            $("#GiongKhachHang").change(function () {
                if ($(this).prop("checked")) {
                    $(this).val(true);

                    $(".delivery-info").addClass("d-none")
                } else {
                    $(this).val(false);

                    $(".delivery-info").removeClass("d-none")
                }
            });
        });
    </script>
}
